# Copy to secrets.yml (gitignored) and fill in.
# Once values are working, encrypt with:
#   ansible-vault encrypt group_vars/all/secrets.yml
#
# Variable names here are canonical — main.yml references these directly,
# no `secret_*` indirection layer. Keep them in sync with main.yml.

# Proxmox API password for the user defined in main.yml (root@pam).
proxmox_api_password: "your-pve-root-password"

# Token auth alternative. Uncomment and switch main.yml's
# `proxmox_api_user` line to the token form when you migrate.
# proxmox_api_token_id: "TOKEN_NAME"
# proxmox_api_token_secret: "TOKEN_VALUE"

# Root password baked into newly-created LXCs at create time.
lxc_root_password: "changeme"

# Pi-hole web admin password.
pihole_web_password: "set-something-real"

# Vaultwarden admin token.
vaultwarden_admin_token: "set-a-strong-random-token"

# Cloudflare tunnel credentials.
# After `cloudflared tunnel create <name>` on a workstation, paste the
# contents of ~/.cloudflared/<UUID>.json here as a dict. main.yml's
# `cloudflared_tunnel_id` reads `TunnelID` out of this dict, so the UUID
# only ever lives in this file.
cloudflared_tunnel_credentials:
  AccountTag: "your-cloudflare-account-tag"
  TunnelID: "the-tunnel-uuid"
  TunnelSecret: "the-base64-tunnel-secret"
