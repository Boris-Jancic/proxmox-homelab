# Managed by Ansible (roles/nginx-proxy/templates/vhost.conf.j2).
# Edits here are overwritten on next playbook run.

{% set is_https_backend = item.destination.startswith('https://') or item.backend_ssl | default(false) -%}
{% if item.ssl | default(false) %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ item.domain }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ item.domain }};

    ssl_certificate {{ item.ssl_cert }};
    ssl_certificate_key {{ item.ssl_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
{% else %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ item.domain }};
{% endif %}

    client_max_body_size {{ nginx_client_max_body_size }};

{% if item.redirect_root_to is defined %}
    location = / {
        return 301 {{ item.redirect_root_to }};
    }

{% endif %}
    location / {
        proxy_pass {{ item.destination }};
{% if is_https_backend %}
        proxy_ssl_verify off;
        proxy_ssl_server_name on;
{% endif %}

        proxy_set_header Host $host;
        # $remote_addr resolves to CF-Connecting-IP for tunnel traffic via
        # the realip module (see /etc/nginx/conf.d/proxy-headers.conf).
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Use the upstream's X-Forwarded-Proto when present (cloudflared
        # terminates TLS at the edge and tells us via the header), else the
        # local listener's scheme. Without this, Proxmox + Nextcloud-AIO
        # admin set Secure cookies that the browser then refuses to send.
        proxy_set_header X-Forwarded-Proto $proxy_x_forwarded_proto;

        # Websocket upgrade — needed for Proxmox noVNC console, Vaultwarden
        # live-sync, and harmless for everything else.
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_read_timeout {{ nginx_proxy_read_timeout }};
        proxy_send_timeout {{ nginx_proxy_read_timeout }};
{% if item.extra_config is defined %}

        {{ item.extra_config | indent(8) }}
{% endif %}
    }
}
