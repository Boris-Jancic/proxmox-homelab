# Managed by Ansible (roles/homepage/templates/services.yaml.j2).
# User-facing `href` links go through nginx-proxy at <sub>.{{ cloudflare_zone }}
# so external (Cloudflare-proxied) and LAN access both work.
# Widget `url` fields stay on internal IPs — the homepage container talks to
# them directly so DNS/Cloudflare round-trips don't slow widget refreshes.
#
# Widget secrets use homepage's HOMEPAGE_VAR_* env-var substitution so
# secrets.yml values never land in this file. The compose template wires the
# env vars in.

- Infrastructure:
    - Proxmox:
        href: https://proxmox.{{ cloudflare_zone }}/
        description: PVE node management
        icon: proxmox.png

    - Pi-hole:
        href: https://pihole.{{ cloudflare_zone }}/admin/
        description: DNS + ad-block
        icon: pi-hole.png
        widget:
          type: pihole
          url: http://{{ hostvars['pi-hole'].ansible_host }}
          # `version: 6` is required for pi-hole v6+ — without it the widget
          # talks to v5 API paths and silently shows empty stats.
          version: 6
          # Set in compose env as HOMEPAGE_VAR_PIHOLE_KEY. v6 accepts the
          # web admin password or an app-password from /admin > Settings > API.
          key: '{% raw %}{{HOMEPAGE_VAR_PIHOLE_KEY}}{% endraw %}'

    - Nginx Proxy:
        # No public vhost — admin of the proxy itself stays on the LAN IP.
        href: http://{{ hostvars['nginx-proxy'].ansible_host }}/
        description: Reverse proxy (manual config)
        icon: nginx.png

- Services:
    - Vaultwarden:
        href: https://vaultwarden.{{ cloudflare_zone }}/
        description: Password manager
        icon: vaultwarden.png

    - Uptime Kuma:
        href: https://kuma.{{ cloudflare_zone }}/
        description: Service uptime monitor
        icon: uptime-kuma.png
        # Uncomment once you've created an API key in Uptime Kuma settings,
        # added it to secrets.yml as `uptime_kuma_api_key`, and exposed it
        # via HOMEPAGE_VAR_UPTIMEKUMA_KEY in the compose template.
        # widget:
        #   type: uptimekuma
        #   url: http://{{ hostvars['uptime-kuma'].ansible_host }}:3001
        #   slug: <status-page-slug>

- Storage:
    - Nextcloud:
        href: https://nextcloud.{{ cloudflare_zone }}/
        description: File storage + sync
        icon: nextcloud.png
