services:
  homepage:
    image: {{ homepage_image }}
    container_name: homepage
    restart: unless-stopped
    ports:
      - "{{ homepage_host_port }}:3000"
    volumes:
      - {{ homepage_config_dir }}:/app/config
    environment:
      HOMEPAGE_ALLOWED_HOSTS: "{{ homepage_allowed_hosts }}"
      # Widget secrets injected as HOMEPAGE_VAR_*; services.yaml references
      # them via {{ '{{HOMEPAGE_VAR_FOO}}' }} substitution. Keeps secrets
      # out of the rendered config files on the CT.
      HOMEPAGE_VAR_PIHOLE_KEY: "{{ pihole_web_password | default('') }}"
